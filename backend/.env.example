# ============================================================
# KumbhSathi AI — Backend Environment (copy to .env)
# ============================================================

# ---- Application ----
APP_NAME=KumbhSathi AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ---- Database (PostgreSQL + PostGIS + pgvector) ----
# For local (non-docker) dev, point host to localhost.
# Inside docker-compose, host is the service name "db".
DATABASE_URL=postgresql+asyncpg://kumbhsathi_user:kumbhsathi_secure_2027@localhost:5432/kumbhsathi
DATABASE_ECHO=false

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- JWT Auth (CHANGE IN PRODUCTION) ----
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# ---- CORS (JSON array) ----
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ---- AI / ML ----
FACE_RECOGNITION_THRESHOLD=0.6
FACE_RECOGNITION_MODEL=hog
DUPLICATE_SIMILARITY_THRESHOLD=0.75
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ---- Aadhaar (CHANGE SALT IN PRODUCTION) ----
AADHAAR_HASH_SALT=kumbhsathi-aadhaar-salt-change-in-production
AADHAAR_RECORD_EXPIRY_DAYS=30

# ---- LLM (AI Interview Agent) ----
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# ---- CSV Data Paths ----
CSV_MISSING_PERSONS=./data/Synthetic_Missing_Persons_2500.csv
CSV_CCTV_LOCATIONS=./data/CCTV_Locations.csv
CSV_POLICE_STATIONS=./data/Police_Stations.csv
CSV_ZONE_BOUNDARIES=./data/Zone_Boundaries.csv
CSV_CHOKEPOINTS=./data/Chokepoints_Parking.csv
